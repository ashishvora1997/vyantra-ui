{
  "name": "@vyantra/ui",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Vyantra UI — a lightweight, modular React design system with accessible components and design tokens.",
  "license": "MIT",
  "author": {
    "name": "Ashish Vora",
    "url": "https://github.com/ashishvora1997"
  },
  "keywords": [
    "vyantra",
    "design-system",
    "react-ui",
    "ui-components",
    "react-components",
    "component-library",
    "lightweight-ui",
    "design-tokens",
    "react-design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/ashishvora1997/vyantra-ui/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.css\" dist/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@vyantra/tokens": "^0.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "copyfiles": "^2.4.1",
    "jsdom": "^24.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashishvora1997/vyantra-ui.git"
  },
  "homepage": "https://github.com/ashishvora1997/vyantra-ui#readme"
}
